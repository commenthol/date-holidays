  "type": "module",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./src/index.js",
      "require": "./lib/index.cjs"
    },
    "./data": {
      "import": "./src/data.js",
      "require": "./lib/data.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./lib/index.cjs",
  "module": "./src/index.js",
  "types": "./types/index.d.ts",
  "bin": {
    "holidays2json": "scripts/holidays2json.cjs"
  },
  "directories": {
    "lib": "lib",
    "doc": "docs",
    "test": "test"
  },
  "scripts": {
    "all": "npm-run-all clean build lint test doc:tree doc:attrib webpack",
    "build": "npm-run-all yaml build:only",
    "build:only": "rollup -c",
    "changelog": "contributors && node scripts/gitlog.cjs",
    "ci": "TEST_XXL=1 npm-run-all yaml build test",
    "clean": "rimraf lib dist src/data.js",
    "clean:all": "npm-run-all clean clean:modules",
    "clean:modules": "rimraf node_modules",
    "doc:attrib": "node scripts/attributions.cjs",
    "doc:tree": "node scripts/addtree.cjs",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "prepublishOnly": "npm run all",
    "fixtures": "mocha test/all.mocha.js --writetests --countries",
    "test": "npm-run-all test:*",
    "test:ci": "mocha",
    "test:ts": "tstyche",
    "watch": "watch-run -p data/countries/*.yaml npm run yaml",
    "webpack": "webpack",
    "webpack:analyze": "webpack",
    "yaml": "node scripts/holidays2json.cjs",
    "prepare": "husky install"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "type-enum": [
        2,
        "always",
        [
          "break",
          "feat",
          "fix",
          "chore",
          "docs",
          "refactor",
          "revert",
          "test"
        ]
      ],
      "subject-case": [
        2,
        "never",
        [
          "start-case",
          "pascal-case"
        ]
      ],
      "scope-case": [
        0
      ]
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not ie <= 10"
  ],
  "mocha": {
    "checkLeaks": true,
    "colors": true,
    "reporter": "dot"
  },
  "dependencies": {
    "date-holidays-parser": "^3.4.7",
    "js-yaml": "^4.1.1",
    "lodash": "^4.18.1",
    "prepin": "^1.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.5",
    "@commitlint/cli": "^18.6.1",
    "@commitlint/config-conventional": "^18.6.3",
    "@eslint/js": "^10.0.1",
    "@mocha/contributors": "git+https://github.com/commenthol/contributors.git#semver:1.1.0-0",
    "babel-loader": "^9.2.1",
    "eslint": "^10.4.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-n": "^18.0.1",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-yml": "^3.3.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "mocha": "^11.7.5",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.3",
    "rollup": "^2.80.0",
    "tstyche": "^4.3.0",
    "watch-run": "^1.2.5",
    "webpack": "^5.107.0",
    "webpack-bundle-analyzer": "^4.10.2",
    "webpack-cli": "^5.1.4"
  },
  "engines": {
    "node": ">=12.0.0"
  },
  "c4uIgnore": {
    "rollup": "^2.79.1 // v3 changed exports; needs refactoring first."
  },
  "packageManager": "pnpm@9.15.4+sha512.b2dc20e2fc72b3e18848459b37359a32064663e5627a51e4c74b2c29dd8e8e0491483c3abb40789cfd578bf362fb6ba8261b05f0387d76792ed6e23ea3b1b6a0"
